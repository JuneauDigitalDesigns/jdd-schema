{
  "name": "@jdd/schema",
  "version": "1.0.0",
  "description": "Canonical intake / SiteContent schema + onboarding-form→intake mapper shared by juneau-digital-designs (producer) and jdd-ops (consumer). Single source of truth for the over-the-wire contract.",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test \"test/**/*.test.mjs\""
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "license": "UNLICENSED",
  "private": false
}
